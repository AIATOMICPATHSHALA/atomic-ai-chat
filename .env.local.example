# Gemini
GEMINI_API_KEY=

# PostgreSQL + Auth.js
# Required to enable server-backed accounts, synced history, and profile settings.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/atomic_ai?schema=public
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
# Use 2027 by default to issue Atomic IDs such as AP2027-000001.
ATOMIC_ID_YEAR=2027
# Optional comma-separated addresses that should receive the ADMIN role on first sign-in.
ATOMIC_ADMIN_EMAILS=
# Bootstrap the first administrator on the first protected server request.
ADMIN_EMAIL=firozali78644@gmail.com
ADMIN_PASSWORD=
# Optional secure mail/webhook gateway for password reset delivery.
PASSWORD_RESET_WEBHOOK_URL=
# Chat audits remain unavailable to admins unless this is explicitly enabled.
ALLOW_ADMIN_CHAT_AUDIT=false

# Optional Google OAuth. The email/password flow remains available without these.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional Supabase Auth
# When these are set, the login screen uses Supabase email/password auth.
# Without these, the app uses local browser login for development/demo mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
